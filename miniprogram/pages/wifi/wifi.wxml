<!--pages/wifi/wifi.wxml-->
<view class="container">
  <!-- 连接状态 -->
  <view class="card">
    <view class="status-header">
      <text class="status-dot {{connected ? 'connected' : 'disconnected'}}"></text>
      <text class="status-text">{{connected ? '设备已连接' : '设备未连接'}}</text>
    </view>
  </view>

  <!-- WiFi配置表单 -->
  <view class="card">
    <view class="card-title">
      <text>WiFi 配置</text>
      <text class="icon">📶</text>
    </view>

    <view class="form-item">
      <text class="form-label">WiFi 名称 (SSID)</text>
      <input 
        class="form-input" 
        placeholder="请输入WiFi名称" 
        value="{{ssid}}"
        bindinput="onSSIDInput"
        disabled="{{!connected}}"
      />
    </view>

    <view class="form-item">
      <text class="form-label">WiFi 密码</text>
      <input 
        class="form-input" 
        placeholder="请输入WiFi密码" 
        value="{{password}}"
        bindinput="onPasswordInput"
        password="{{!showPassword}}"
        disabled="{{!connected}}"
      />
      <view class="password-toggle" bindtap="togglePassword">
        <text>{{showPassword ? '👁️' : '🔒'}}</text>
      </view>
    </view>

    <view class="scan-button">
      <button 
        class="btn-secondary" 
        bindtap="scanWifi"
        disabled="{{!connected || scanning}}"
        loading="{{scanning}}"
      >
        {{scanning ? '扫描中...' : '📡 扫描WiFi'}}
      </button>
    </view>

    <!-- 扫描结果 -->
    <view wx:if="{{wifiList.length > 0}}" class="wifi-list">
      <view 
        class="wifi-item {{ssid === item.ssid ? 'selected' : ''}}" 
        wx:for="{{wifiList}}" 
        wx:key="ssid"
        bindtap="selectWifi"
        data-ssid="{{item.ssid}}"
      >
        <view class="wifi-icon">📶</view>
        <view class="wifi-detail">
          <text class="wifi-name">{{item.ssid}}</text>
          <text class="wifi-signal">{{item.signal}} dBm</text>
        </view>
        <view wx:if="{{ssid === item.ssid}}" class="check-icon">✓</view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="button-group">
    <button 
      class="btn-primary" 
      bindtap="saveConfig"
      disabled="{{!connected || !ssid || !password || saving}}"
      loading="{{saving}}"
    >
      {{saving ? '保存中...' : '保存配置'}}
    </button>
  </view>

  <!-- 提示 -->
  <view class="tips">
    <view class="tip-item">
      <text class="tip-icon">⚠️</text>
      <text class="tip-text">请确保墨水屏与路由器的距离不要太远</text>
    </view>
  </view>
</view>
