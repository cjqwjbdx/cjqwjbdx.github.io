/* pages/index/index.wxss */
.status-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.device-info {
  padding-top: 20rpx;
  border-top: 1rpx solid #EEEEEE;
}

.device-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.device-id {
  font-size: 24rpx;
  color: #999999;
}

.card-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title text:first-child {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.device-count {
  font-size: 24rpx;
  color: #999999;
}

.device-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.device-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.device-item:last-child {
  border-bottom: none;
}

.device-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.device-icon image {
  width: 48rpx;
  height: 48rpx;
}

.device-detail {
  flex: 1;
}

.device-detail .device-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.device-rssi {
  font-size: 24rpx;
  color: #999999;
}

.device-arrow {
  font-size: 48rpx;
  color: #CCCCCC;
  font-weight: 300;
}

.button-group {
  margin-top: 40rpx;
}

.tips {
  margin-top: 60rpx;
  padding: 0 20rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf3 100%);
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}
