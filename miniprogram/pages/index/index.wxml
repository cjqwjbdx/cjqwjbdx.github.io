<!--pages/index/index.wxml-->
<view class="container">
  <!-- 状态卡片 -->
  <view class="card">
    <view class="status-header">
      <text class="status-dot {{statusClass}}"></text>
      <text class="status-text">{{statusText}}</text>
    </view>
    <view wx:if="{{connectedDeviceName}}" class="device-info">
      <text class="device-name">{{connectedDeviceName}}</text>
      <text class="device-id">ID: {{deviceId}}</text>
    </view>
  </view>

  <!-- 设备列表 -->
  <view wx:if="{{devices.length > 0}}" class="card">
    <view class="card-title">
      <text>发现设备</text>
      <text class="device-count">{{devices.length}} 台</text>
    </view>
    <view class="device-list">
      <view 
        class="device-item" 
        wx:for="{{devices}}" 
        wx:key="deviceId"
        bindtap="connectDevice"
        data-device="{{item}}"
      >
        <view class="device-icon">
          <image src="/images/device-icon.png"></image>
        </view>
        <view class="device-detail">
          <text class="device-name">{{item.name}}</text>
          <text class="device-rssi">信号: {{item.rssi}} dBm</text>
        </view>
        <view class="device-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="button-group">
    <button 
      wx:if="{{!connected}}" 
      class="btn-primary" 
      bindtap="startSearch"
      loading="{{searching}}"
    >
      {{searching ? '搜索中...' : '搜索设备'}}
    </button>
    <button 
      wx:else 
      class="btn-secondary" 
      bindtap="disconnect"
    >
      断开连接
    </button>
  </view>

  <!-- 提示信息 -->
  <view class="tips">
    <view class="tip-item">
      <text class="tip-icon">💡</text>
      <text class="tip-text">请确保墨水屏已开机且蓝牙已开启</text>
    </view>
    <view class="tip-item">
      <text class="tip-icon">📱</text>
      <text class="tip-text">连接成功后可配置WiFi和参数</text>
    </view>
  </view>
</view>
